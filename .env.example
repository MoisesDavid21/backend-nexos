# ==============================================================================
# PRISMA DELIVERY API - Variables de Entorno
# ==============================================================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas tu archivo .env a Git.
# ==============================================================================

# Puerto del servidor (Render asigna el suyo automáticamente)
PORT=3000

# Entorno: development | production
NODE_ENV=development

# URL de conexión a PostgreSQL (Connection String)
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB
# Ejemplo con Render: postgresql://prisma_user:abc123@dpg-xyz.render.com:5432/prisma_db
DATABASE_URL=postgresql://postgres:admin@localhost:5432/prisma

# JWT Secret para autenticación (futuro)
JWT_SECRET=tu_jwt_secreto_super_seguro_2026
